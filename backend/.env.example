PORT=5000
NODE_ENV=development

# Database (Supabase direct connection)
# Get this from Supabase Project Settings > Database > Connection pooler 
# Or direct connection string: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:pass@db.url:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP with App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
EMAIL_FROM="ChitGPT" <your-email@gmail.com>

# AI Providers (At least one required)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=gemini # or 'openai', 'groq'

# App Settings
FRONTEND_URL=http://localhost:3000
